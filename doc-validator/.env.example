# Copy to doc-validator/.env and fill in. This file (.env) is gitignored.
# Azure OpenAI (GPT-4o) - used for the detailed LLM title-block review.
AZURE_OPENAI_API_KEY=your-azure-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Optional: path to the Tesseract OCR binary, only needed if it is NOT on PATH
# (the "Text inside images is selectable" check uses it; no LLM/API cost).
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
